# Caddy reverse proxy with automatic HTTPS via Let's Encrypt.
#
# Replace net.speednet.iq with your real domain and make sure the domain's
# A/AAAA record points at this host. Caddy obtains + renews the certificate
# automatically on first request — no certbot, no cron.
#
# Run with deploy/docker-compose.prod.yml (service `caddy`).

net.speednet.iq {
	encode gzip

	# --- Security headers (defense in depth) ---
	header {
		# Force HTTPS for a year on this host + subdomains
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Don't let browsers guess content types
		X-Content-Type-Options "nosniff"
		# Block clickjacking (can't be embedded in a frame)
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Restrict what the page may load. 'self' only, plus Google Fonts
		# (the UI uses IBM Plex) and inline styles/scripts the SPA needs.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		# Don't advertise the server software
		-Server
	}

	# API → backend (FastAPI). Backend is only reachable on the internal network.
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Health check passthrough (optional)
	handle /health {
		reverse_proxy backend:8000
	}

	# Everything else → static SPA served by the frontend nginx container.
	handle {
		reverse_proxy frontend:80
	}
}
