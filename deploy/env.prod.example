# =============================================================================
# PRODUCTION environment for the SPEEDNeT Console (on-prem, e.g. the R710).
#
#   cp deploy/env.prod.example .env      # then edit every CHANGE_ME below
#
# The stack reads this file from the REPO ROOT as `.env`. Never commit it.
# Generate a secret key with:   openssl rand -hex 32
# =============================================================================

# ---- Database (runs in the `db` container; not exposed to the network) ----
POSTGRES_USER=speednet
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=speednet
# Host is `db` — the internal docker-compose service name. Keep the password
# here identical to POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+asyncpg://speednet:CHANGE_ME_strong_db_password@db:5432/speednet

# ---- Auth ----
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- First-run admin (seeded automatically on first start) ----
ADMIN_EMAIL=admin@speednet.iq
ADMIN_PASSWORD=CHANGE_ME_admin_password

# ---- CORS ----
# Same-origin behind Caddy, so this is belt-and-suspenders. Use your real
# public URL (https). JSON array form.
CORS_ORIGINS=["https://console.speednet.iq"]

# ---- IP monitor (works here because the server is ON the network) ----
MONITOR_ENABLED=true
MONITOR_PRIVILEGED=true       # raw ICMP; prod compose grants NET_RAW
MONITOR_CONCURRENCY=50
MONITOR_COUNT=1
MONITOR_TIMEOUT=1.0
MONITOR_CYCLE_GAP=10.0
MONITOR_REFRESH_IPS=120.0

# ---- Down-alert notifications (optional — off until you configure a channel) ----
ALERT_ENABLED=false
# Generic webhook (Telegram bot proxy / Slack / Discord / n8n …):
ALERT_WEBHOOK_URL=
# …or SMTP email (all of these must be set to send):
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
# …or Telegram directly (no proxy needed). Get the token from @BotFather, then
# send your bot a message and read the chat id from
#   https://api.telegram.org/bot<TOKEN>/getUpdates  -> result[].message.chat.id
# A bot CANNOT message you until you have messaged it first (or added it to the
# group) — that's the usual reason a correct-looking token still sends nothing.
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
# Base URL used to build "Open in console →" links inside alerts:
ALERT_LINK_BASE_URL=https://speednetiq.duckdns.org

# ---- Automatic backups (CSV archives of every table -> ./backups) ----
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_DIR=backups
BACKUP_RETENTION=28

# ---- Not used on-prem (only for the cloud + agent setup). Leave empty. ----
MONITOR_AGENT_TOKEN=

# ---- UBNT scan fallback creds (scripts/scan_ubnt.py) ----
UBNT_FALLBACK_CREDS=ubnt:ubnt
