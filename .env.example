# ---- Database ----
POSTGRES_USER=speednet
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=speednet
DATABASE_URL=postgresql+asyncpg://speednet:CHANGE_ME_strong_password@db:5432/speednet

# ---- Auth ----
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- Admin seed (used by import_sheet.py on first run) ----
ADMIN_EMAIL=admin@speednet.iq
ADMIN_PASSWORD=CHANGE_ME_admin_password

# ---- CORS (frontend origin) ----
CORS_ORIGINS=["http://localhost:5173"]

# ---- IP monitor (background ping of every IP in the DB) ----
MONITOR_ENABLED=true
MONITOR_CONCURRENCY=50        # IPs pinged in parallel per batch
MONITOR_COUNT=1              # ICMP packets per host per check
MONITOR_TIMEOUT=1.0         # seconds to wait per packet
MONITOR_CYCLE_GAP=10.0      # idle seconds between full sweeps
MONITOR_REFRESH_IPS=120.0   # how often to re-read the IP list from the DB
# ICMP needs raw sockets. Docker: keep true + cap_add NET_RAW (already set in
# docker-compose.yml). On Linux/macOS bare metal you may set false to use
# unprivileged ICMP. Windows always needs true (run as Administrator).
MONITOR_PRIVILEGED=true

# ---- UBNT scan fallback creds (scripts/scan_ubnt.py) ----
# Comma-separated user:pass pairs tried when a device row has no stored creds.
UBNT_FALLBACK_CREDS=ubnt:ubnt
